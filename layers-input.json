    "welcome": {
        "message": "Explore how Bears Ears and Grand Staircase-Escalante National Monuments have changed from 2016 to 2026. Try asking:",
        "examples": [
            "Overlay the Bears Ears boundary in 2016 and its 2026 proposed reduction.",
            "How many acres did the 2026 proposal cut from Grand Staircase-Escalante compared with its 2021 extent?",
            "Show tribal and community lands (LandMark) around the two monuments.",
            "Which protected areas and federal trails fall inside the 2026 proposed Bears Ears boundary?"
        ]
    },
    "links": {
        "github": "https://github.com/cassiebuhler/utah-public-lands",
        "docs": "https://boettiger-lab.github.io/geo-agent/"
    },
